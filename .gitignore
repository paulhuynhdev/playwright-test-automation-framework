# =============================================================================
#  Dependencies
# =============================================================================
node_modules/

# =============================================================================
#  Environment variables (never commit secrets)
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
#  Build outputs
# =============================================================================
dist/
build/
out/
*.tsbuildinfo

# =============================================================================
#  Test artifacts
# =============================================================================
test-results/
playwright-report/
blob-report/
playwright/.cache/
playwright/.auth/
allure-results/
allure-report/
storage/

# Playwright media (kept under test-results)
*.mp4
*.webm
*.zip

# =============================================================================
#  Coverage
# =============================================================================
coverage/
*.lcov

# =============================================================================
#  Logs
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# =============================================================================
#  OS files
# =============================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
#  Editors / IDEs
# =============================================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# =============================================================================
#  Temporary / cache
# =============================================================================
*.tmp
*.temp
*.swp
*.swo
*.bak
*.old
*.cache

# =============================================================================
#  Tooling / local-only
# =============================================================================
.claude/

# =============================================================================
#  AI test agents (Playwright planner / generator / healer)
# =============================================================================
# Agent defs (.claude/) + MCP registration stay local — regenerate with
# `npx playwright init-agents --loop=claude`. Durable conventions live in
# CLAUDE.md + docs/app.context.md.
.mcp.json
# Raw, unreviewed generator output — staging only. Refactor into specs/features/.
tests/_generated/*
!tests/_generated/README.md
